.git
.gitignore

# Editor
.vscode
.idea
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Tests
coverage
__tests__
*.test.ts
*.test.tsx
*.spec.ts
*.spec.tsx

# Docs
README.md
CHANGELOG.md

# Misc
chaos.tsx
*.rar
*.zip